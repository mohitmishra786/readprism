# Application
APP_ENV=development
SECRET_KEY=change_me_to_a_long_random_string
# Optional distinct signing key for refresh tokens (falls back to SECRET_KEY).
REFRESH_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://readprism:readprism@db:5432/readprism
DATABASE_SYNC_URL=postgresql://readprism:readprism@db:5432/readprism

# Redis
REDIS_URL=redis://redis:6379/0

# LLM — Primary: Groq
GROQ_API_KEY=
GROQ_SUMMARIZATION_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant

# LLM — Fallback: OpenAI (disabled by default)
OPENAI_FALLBACK_ENABLED=false
OPENAI_API_KEY=

# Embeddings (local sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# Email delivery — Zoho SMTP
ZOHO_SMTP_HOST=smtppro.zoho.in
ZOHO_SMTP_PORT=587
ZOHO_EMAIL=admin@mohitmishra7.com
ZOHO_PASSWORD=
FROM_EMAIL=admin@mohitmishra7.com
# Externally-reachable API base URL — builds one-click unsubscribe links in
# digest emails. Set to your public API domain in production.
PUBLIC_API_URL=http://localhost:8000
# Physical mailing address for the email footer (CAN-SPAM). Set for bulk sends.
EMAIL_PHYSICAL_ADDRESS=

# Newsletter ingestion
NEWSLETTER_INBOX_DOMAIN=inbox.readprism.app
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
# Mailgun *Webhook Signing Key* (Settings -> API Security), NOT the API key.
# Required to authenticate the /newsletter/inbound webhook. If unset, the
# webhook is fail-closed outside development (rejects all posts).
MAILGUN_WEBHOOK_SIGNING_KEY=
NEWSLETTER_WEBHOOK_MAX_AGE_SECONDS=900

# Scraping
BROWSERLESS_URL=http://browserless:3000
SCRAPER_MAX_CONCURRENCY=5
# SSRF protection: block private/loopback/link-local/metadata IPs on server-side
# fetches. Keep true for any hosted deployment. Self-hosters ingesting LAN feeds
# on a single-tenant box may set false.
SSRF_PROTECTION_ENABLED=true

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Search (Meilisearch)
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_MASTER_KEY=readprism_search_key

# Rate limiting (Redis-backed) for auth endpoints
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_REGISTER_PER_MINUTE=5

# Feature flags
COLD_START_COLLABORATIVE_ENABLED=true
SERENDIPITY_DEFAULT_PERCENTAGE=15
DIGEST_DEFAULT_ITEMS=12
