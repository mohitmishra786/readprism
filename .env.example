# Application
APP_ENV=development
SECRET_KEY=change_me_to_a_long_random_string
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://readprism:readprism@db:5432/readprism
DATABASE_SYNC_URL=postgresql://readprism:readprism@db:5432/readprism

# Redis
REDIS_URL=redis://redis:6379/0

# LLM — Primary: Groq
GROQ_API_KEY=
GROQ_SUMMARIZATION_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant

# LLM — Fallback: OpenAI (disabled by default)
OPENAI_FALLBACK_ENABLED=false
OPENAI_API_KEY=

# Embeddings (local sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# Email delivery — Zoho SMTP
ZOHO_SMTP_HOST=smtppro.zoho.in
ZOHO_SMTP_PORT=587
ZOHO_EMAIL=admin@mohitmishra7.com
ZOHO_PASSWORD=
FROM_EMAIL=admin@mohitmishra7.com

# Newsletter ingestion
NEWSLETTER_INBOX_DOMAIN=inbox.readprism.app
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# Scraping
BROWSERLESS_URL=http://browserless:3000
SCRAPER_MAX_CONCURRENCY=5

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Search (Meilisearch)
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_MASTER_KEY=readprism_search_key

# Feature flags
COLD_START_COLLABORATIVE_ENABLED=true
SERENDIPITY_DEFAULT_PERCENTAGE=15
DIGEST_DEFAULT_ITEMS=12
